// ============================================================================
// Frontend CI pipeline  (lives WITH the code it builds — pipeline-as-code)
//
// Flow:  checkout -> install/build -> SonarQube -> docker build -> Trivy
//        -> push immutable image -> bump tag in the GitOps repo (mern_cicd)
//
// The image is environment-agnostic (backend URL is injected at runtime), so
// the same tag is what gets promoted dev -> prod through Argo CD.
// ============================================================================
pipeline {
    agent any

    environment {
        SONAR_HOST_URL  = "http://13.235.42.215:9000"
        
        REGISTRY        = "637423622313.dkr.ecr.ap-south-1.amazonaws.com"
        IMAGE           = "637423622313.dkr.ecr.ap-south-1.amazonaws.com/mern-frontend"
        IMAGE_TAG       = "${env.BUILD_NUMBER}"

        AWS_REGION      = "ap-south-1"

    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
    }

    stages {

        // stage('SonarQube Analysis') {
        //     steps {
                
        //         withCredentials([string(credentialsId: 'sonar_token', variable: 'SONAR_TOKEN')]) {
        //             sh "cd frontend; sonar -Dsonar.host.url=${SONAR_HOST_URL} -Dsonar.login=${SONAR_TOKEN}"
        //         }
        //     }
        // }

        stage('Docker Build') {
            steps {
                dir('frontend') { 
                    script {
                        image = docker.build("${IMAGE}:${IMAGE_TAG}", ".")
                    }
                }
            }
        }

        // stage('Trivy Scan') {
        //     steps {
        //         sh "trivy image --severity LOW,MEDIUM,HIGH --exit-code 0 --format table ${IMAGE}:${IMAGE_TAG}"
        //         sh "trivy image --severity CRITICAL --exit-code 0 --ignore-unfixed --format table ${IMAGE}:${IMAGE_TAG}"
        //     }
        // }
        
        stage('Push Image') {
            environment {
                AWS_ACCESS_KEY_ID = credentials('AWS_ACCESS_KEY_ID')
                AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
            }
            steps {
                sh '''
                    aws ecr get-login-password --region ${AWS_REGION} \
                      | docker login --username AWS --password-stdin ${REGISTRY}
                    docker push ${IMAGE}:${IMAGE_TAG}
                '''
            }
        }

        stage('Helm Deploy') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig-file', variable: 'KUBECONFIG')]) {
                    sh '''
                        helm upgrade --install frontend ./CICD/deploy/helm/frontend \
                        --namespace frontend \
                        --create-namespace \
                        --set image.repository=$IMAGE \
                        --set image.tag=$IMAGE_TAG
                    '''
                }
            }
        }
    }

}
